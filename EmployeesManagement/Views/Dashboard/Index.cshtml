@model EmployeesManagement.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="content-header">
    <div class="container-fluid">

        <h2 class="mb-4">
            Dashboard
        </h2>

        <div class="row">

            <!-- Total Employees -->
            <div class="col-lg-3 col-6">

                <div class="small-box bg-info">

                    <div class="inner">

                        <h3>@Model.TotalEmployees</h3>

                        <p>Total Employees</p>

                    </div>

                    <div class="icon">
                        <i class="fas fa-users"></i>
                    </div>

                    <a asp-controller="Employees"
                       asp-action="Index"
                       class="small-box-footer">

                        View Employees
                        <i class="fas fa-arrow-circle-right"></i>

                    </a>

                </div>

            </div>


            <div class="col-lg-3 col-6">

                <div class="small-box bg-info">

                    <div class="inner">

                        <h3>@Model.TotalDepartments</h3>
                        <p>Departments</p>

                    </div>

                    <div class="icon">
                        <i class="fas fa-users"></i>
                    </div>

                    <a asp-controller="Employees"
                       asp-action="Index"
                       class="small-box-footer">

                        View Departments
                        <i class="fas fa-arrow-circle-right"></i>

                    </a>

                </div>

            </div>


            <div class="col-lg-3 col-6">

                <div class="small-box bg-info">

                    <div class="inner">

                        <h3>@Model.TotalDesignations</h3>
                        <p>Designations</p>

                    </div>

                    <div class="icon">
                        <i class="fas fa-users"></i>
                    </div>

                    <a asp-controller="Employees"
                       asp-action="Index"
                       class="small-box-footer">

                        View Designations
                        <i class="fas fa-arrow-circle-right"></i>

                    </a>

                </div>

            </div>
        </div>

        <div class="card">

            <div class="card-header">

                <h3 class="card-title">
                    <i class="fas fa-users mr-2"></i>
                    Recent Employees
                </h3>

                <div class="card-tools">
                    <a asp-controller="Employees"
                       asp-action="Index"
                       class="btn btn-sm btn-primary">
                        View All
                    </a>
                </div>

            </div>

            <div class="card-body p-0">

                <table class="table table-hover text-nowrap">

                    <thead>
                        <tr>
                            <th>Employee No</th>
                            <th>Name</th>
                            <th>Department</th>
                            <th>Designation</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model.RecentEmployees)
                        {
                            <tr>
                                <td>@item.EmpNo</td>
                                <td>@item.FullName</td>
                                <td>@item.Department</td>
                                <td>@item.Designation</td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>
    </div>
</div>