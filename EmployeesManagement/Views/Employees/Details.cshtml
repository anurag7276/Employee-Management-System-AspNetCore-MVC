@model EmployeesManagement.Models.Employee

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div class="card card-primary card-outline">

    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-user mr-2"></i>
            Employee Details
        </h3>

        <div class="card-tools">
            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-warning btn-sm">
                <i class="fas fa-edit"></i> Edit
            </a>

            <a asp-action="Index"
               class="btn btn-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <div class="card-body">

        <div class="row">

            <div class="col-md-6">

                <strong>Employee No</strong>
                <p class="text-muted">@Model.EmpNo</p>

                <hr>

                <strong>Full Name</strong>
                <p class="text-muted">@Model.FullName</p>

                <hr>

                <strong>Email</strong>
                <p class="text-muted">@Model.EmailAddress</p>

                <hr>

                <strong>Phone Number</strong>
                <p class="text-muted">@Model.PhoneNumber</p>

                <hr>

                <strong>Country</strong>
                <p class="text-muted">@Model.Country</p>

                <hr>

                <strong>Date of Birth</strong>
                <p class="text-muted">
                    @Model.DateOfBirth.ToString("dd MMM yyyy")
                </p>

            </div>

            <div class="col-md-6">

                <strong>Department</strong>
                <p class="text-muted">@Model.Department</p>

                <hr>

                <strong>Designation</strong>
                <p class="text-muted">@Model.Designation</p>

                <hr>

                <strong>Address</strong>
                <p class="text-muted">@Model.Address</p>

                <hr>

                <strong>Created On</strong>
                <p class="text-muted">
                    @Model.CreatedOn.ToString("dd MMM yyyy")
                </p>

                <hr>

                <strong>Modified On</strong>
                <p class="text-muted">
                    @Model.ModifiedOn.ToString("dd MMM yyyy")
                </p>

            </div>

        </div>

    </div>


